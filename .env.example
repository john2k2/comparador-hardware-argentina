# ============================================
# Variables de Entorno - Comparador Hardware
# ============================================
# Copiar este archivo a .env.local y completar los valores

# ============================================
# SUPABASE (Requeridas)
# ============================================

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (usada por el cliente)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=tu-publishable-key
SUPABASE_PUBLISHABLE_KEY=tu-publishable-key

# Clave secreta (SOLO para uso server-side)
# NUNCA expongas esta clave en el cliente
SUPABASE_SECRET_KEY=tu-secret-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_ANON_KEY=tu-anon-key

# Clave de servicio (SOLO para migraciones y operaciones privileged)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ============================================
# SITIO (Requeridas para SEO)
# ============================================

# URL canonical del sitio (sin slash al final)
SITE_URL=https://www.comparador-hardware.com.ar

# Token de verificación de Google Search Console
# Obtener desde: https://search.google.com/search-console
GOOGLE_SITE_VERIFICATION=tu-token-de-verificacion

# Email de soporte
SUPPORT_EMAIL=contacto@comparador-hardware.com.ar

# ============================================
# GEMINI AI (Opcional - mejora normalización)
# ============================================

# API Key de Google AI Studio
# Obtener desde: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-gemini-api-key

# Configuración de batches (opcional)
GEMINI_BATCH_TIMEOUT_MS=3500
GEMINI_BATCH_SIZE=15
GEMINI_BATCH_CONCURRENCY=2
GEMINI_MAX_BATCHES_PER_REQUEST=16

# ============================================
# CLOUDFLARE (Opcional - para PortalTech)
# ============================================

CLOUDFLARE_API_TOKEN=tu-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=tu-cloudflare-account-id

# ============================================
# CRON / SCHEDULER (Opcional)
# ============================================

# Secreto para endpoints de cron (debe ser seguro, min 32 caracteres)
CRON_SECRET=tu-cron-secret-seguro-min-32-chars

# Secreto específico para refresh de catálogo
CATALOG_REFRESH_CRON_SECRET=tu-catalog-refresh-secret

# Desactivar refresh interno (1 = disabled)
# DISABLE_INTERNAL_BACKGROUND_REFRESH=1

# ============================================
# ANALYTICS (Opcional)
# ============================================

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# LOGGING (Opcional)
# ============================================

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=info
NEXT_PUBLIC_LOG_LEVEL=warn

# ============================================
# FEATURES (Opcional)
# ============================================

# IDs de tiendas sponsor (separados por coma)
NEXT_PUBLIC_SPONSORED_STORE_IDS=mexx,venex

# ============================================
# VERIFICACIÓN
# ============================================
# Para verificar que todo funciona:
# 1. npm run build
# 2. npm run lint
# 3. npm test
